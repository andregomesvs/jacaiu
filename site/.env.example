# ============================================
# JÁ CAIU? — Variáveis de Ambiente do Site
# Copie este arquivo para .env.local e preencha
# NUNCA commite o .env.local no Git!
# ============================================

# --- SUPABASE ---
# Encontre em: supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- RESEND (e-mails) ---
# Encontre em: resend.com > API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# --- STEAM API ---
# Obtenha em: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- FACEIT API ---
# Registre em: https://developers.faceit.com
FACEIT_API_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# --- ONESIGNAL (push notifications) ---
# Encontre em: onesignal.com > seu app > Settings > Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
ONESIGNAL_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- URL do site (para e-mails e redirects) ---
NEXT_PUBLIC_SITE_URL=https://jacaiu.app
